{
  "manifest_version": 3,
  "name": "Website Blocker",
  "version": "0.2.0",
  "description": "A simple website blocker.",
  "permissions": [
    "tabs",
    "webNavigation",
    "declarativeNetRequest",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html"
}
